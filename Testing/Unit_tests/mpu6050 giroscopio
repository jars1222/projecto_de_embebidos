#include "I2Cdev.h"
#include "Wire.h"
#include "MPU6050.h"

MPU6050 sensor;

int16_t gx, gy, gz;

unsigned long tiempo_prev = 0;
float dt;

float girome_ang_x = 0;
float girome_ang_y = 0;

void setup() {
  Serial.begin(57600);
  Wire.begin();
  sensor.initialize();
}

void loop() {

  // Leer velocidad angular del giroscopio
  sensor.getRotation(&gx, &gy, &gz);

  // Calcular tiempo transcurrido
  dt = (millis() - tiempo_prev) / 1000.0;
  tiempo_prev = millis();

  // Integración del giroscopio
  girome_ang_x = girome_ang_x + (gx / 131.0) * dt;
  girome_ang_y = girome_ang_y + (gy / 131.0) * dt;

  Serial.print("rotacion en x: ");
  Serial.print(girome_ang_x);

  Serial.print("  rotacion en y: ");
  Serial.println(girome_ang_y);

  delay(500);
}
