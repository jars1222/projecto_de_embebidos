#include "I2Cdev.h"
#include "MPU6050.h"
#include "Wire.h"

// Objeto del sensor
MPU6050 sensor;

// Variables del acelerómetro
int16_t ax, ay, az;

void setup() {

  // Velocidad serial más segura para Pro Mini
  Serial.begin(9600);

  // Iniciar comunicación I2C
  Wire.begin();

  // Inicializar sensor
  sensor.initialize();

  // Verificar conexión
  if (sensor.testConnection()) {
    Serial.println("Sensor iniciado");
  } else {
    Serial.println("Error al iniciar el sensor");
  }
}

void loop() {

  // Leer aceleración
  sensor.getAcceleration(&ax, &ay, &az);

  // Calcular ángulo en X
  float accel_ang_x = atan(ax / sqrt(pow(ay, 2) + pow(az, 2))) * (180.0 / PI);

  // Calcular ángulo en Y
  float accel_ang_y = atan(ay / sqrt(pow(ax, 2) + pow(az, 2))) * (180.0 / PI);

  Serial.print("Inclinacion X: ");
  Serial.print(accel_ang_x);

  Serial.print("  Inclinacion Y: ");
  Serial.println(accel_ang_y);

  delay(500);
}
