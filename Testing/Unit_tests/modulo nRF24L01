#include <SPI.h>
#include <RF24.h>

RF24 radio(9,10); // CE, CSN

const byte direccion[6] = "00001";

void setup() {
  Serial.begin(9600);

  radio.begin();
  radio.openWritingPipe(direccion);
  radio.setPALevel(RF24_PA_MIN);
  radio.stopListening();
}

void loop() {

  const char texto[] = "hola";

  radio.write(&texto, sizeof(texto));

  Serial.println("mensaje enviado");

  delay(1000);
}
